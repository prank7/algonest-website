---

---

<section id="products" class="products">
	<div class="products-inner">
		<div class="section-header">
			<span class="section-tag">Products</span>
			<h2>What we're building</h2>
			<p class="section-sub">
				We build and operate cloud-native AI products — SaaS platforms, mobile apps,
				and automation infrastructure that serve users at scale.
			</p>
		</div>
		<div class="products-grid">
			<div class="product-card featured">
				<div class="product-label">Cloud SaaS Platform</div>
				<h3>AI-Powered Web Applications</h3>
				<p>
					Multi-tenant SaaS platforms with real-time AI inference, user dashboards,
					and API-first architectures. Deployed on cloud infrastructure with
					auto-scaling, edge caching, and managed databases for low-latency
					global delivery.
				</p>
				<div class="product-tags">
					<span class="tag">SaaS</span>
					<span class="tag">Real-Time AI</span>
					<span class="tag">REST / GraphQL APIs</span>
					<span class="tag">Edge Deployment</span>
				</div>
			</div>
			<div class="product-card">
				<div class="product-label">Mobile + On-Device AI</div>
				<h3>AI-Native iOS Apps</h3>
				<p>
					Native iOS applications with on-device ML models and cloud-synced
					AI pipelines. Combines Core ML inference with server-side LLM
					processing for hybrid intelligence.
				</p>
				<div class="product-tags">
					<span class="tag">iOS</span>
					<span class="tag">Core ML</span>
					<span class="tag">Cloud Sync</span>
					<span class="tag">LLM APIs</span>
				</div>
			</div>
			<div class="product-card">
				<div class="product-label">AI Infrastructure</div>
				<h3>Automation & Agent Platform</h3>
				<p>
					Cloud-hosted AI agent orchestration, workflow automation pipelines,
					and data processing infrastructure. GPU-accelerated inference
					for production ML workloads.
				</p>
				<div class="product-tags">
					<span class="tag">AI Agents</span>
					<span class="tag">GPU Compute</span>
					<span class="tag">Data Pipelines</span>
					<span class="tag">Vector DBs</span>
				</div>
			</div>
		</div>
	</div>
</section>

<style>
	.products {
		padding: 6rem 2rem;
	}

	.products-inner {
		max-width: var(--max-width);
		margin: 0 auto;
	}

	.section-header {
		text-align: center;
		margin-bottom: 4rem;
	}

	.section-tag {
		display: inline-block;
		font-size: 0.7rem;
		font-weight: 600;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--color-accent-light);
		margin-bottom: 0.75rem;
	}

	.section-header h2 {
		font-size: clamp(1.75rem, 4vw, 2.5rem);
		font-weight: 700;
		letter-spacing: -0.02em;
		margin-bottom: 1rem;
	}

	.section-sub {
		font-size: 1.05rem;
		line-height: 1.7;
		color: var(--color-text-muted);
		max-width: 520px;
		margin: 0 auto;
	}

	.products-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1.25rem;
	}

	.product-card {
		padding: 2.25rem;
		background: var(--color-bg-card);
		border: 1px solid var(--color-border);
		border-radius: 14px;
		transition: all 0.25s ease;
	}

	.product-card:hover {
		border-color: var(--color-border-hover);
	}

	.product-card.featured {
		grid-row: span 2;
		display: flex;
		flex-direction: column;
		justify-content: center;
		background: linear-gradient(160deg, var(--color-bg-card) 0%, rgba(99, 102, 241, 0.06) 100%);
		border-color: rgba(99, 102, 241, 0.15);
	}

	.product-label {
		font-size: 0.65rem;
		font-weight: 600;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--color-text-dim);
		margin-bottom: 0.75rem;
	}

	.product-card h3 {
		font-size: 1.25rem;
		font-weight: 600;
		margin-bottom: 0.75rem;
	}

	.product-card p {
		font-size: 0.9rem;
		line-height: 1.65;
		color: var(--color-text-muted);
		margin-bottom: 1.5rem;
	}

	.product-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.tag {
		font-size: 0.7rem;
		font-weight: 500;
		padding: 0.3rem 0.75rem;
		background: var(--color-bg-elevated);
		border: 1px solid var(--color-border);
		border-radius: 100px;
		color: var(--color-text-muted);
	}

	@media (max-width: 700px) {
		.products-grid {
			grid-template-columns: 1fr;
		}

		.product-card.featured {
			grid-row: auto;
		}
	}
</style>

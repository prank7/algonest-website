---

---

<section id="products" class="products">
	<div class="products-inner">
		<div class="section-header">
			<span class="section-tag">Products</span>
			<h2>Built in-house</h2>
			<p class="section-sub">
				We don't just consult — we build. Our internal products are crafted with
				the same rigor we bring to every client engagement.
			</p>
		</div>
		<div class="products-grid">
			<div class="product-card featured">
				<div class="product-label">Web Platform</div>
				<h3>Web Products</h3>
				<p>
					Full-stack web applications designed for performance and elegance.
					From SaaS platforms to internal tools — engineered to deliver value
					from day one.
				</p>
				<div class="product-tags">
					<span class="tag">SaaS</span>
					<span class="tag">Dashboards</span>
					<span class="tag">Internal Tools</span>
				</div>
			</div>
			<div class="product-card">
				<div class="product-label">Mobile</div>
				<h3>Mobile Products</h3>
				<p>
					Native iOS and cross-platform mobile experiences
					with AI capabilities baked in — not bolted on.
				</p>
				<div class="product-tags">
					<span class="tag">iOS</span>
					<span class="tag">AI-Native</span>
					<span class="tag">On-Device ML</span>
				</div>
			</div>
			<div class="product-card">
				<div class="product-label">Automation</div>
				<h3>AI Tooling</h3>
				<p>
					Internal automation tools and AI agents that power our
					workflows — and can power yours too.
				</p>
				<div class="product-tags">
					<span class="tag">Agents</span>
					<span class="tag">Pipelines</span>
					<span class="tag">Integrations</span>
				</div>
			</div>
		</div>
	</div>
</section>

<style>
	.products {
		padding: 6rem 2rem;
	}

	.products-inner {
		max-width: var(--max-width);
		margin: 0 auto;
	}

	.section-header {
		text-align: center;
		margin-bottom: 4rem;
	}

	.section-tag {
		display: inline-block;
		font-size: 0.7rem;
		font-weight: 600;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--color-accent-light);
		margin-bottom: 0.75rem;
	}

	.section-header h2 {
		font-size: clamp(1.75rem, 4vw, 2.5rem);
		font-weight: 700;
		letter-spacing: -0.02em;
		margin-bottom: 1rem;
	}

	.section-sub {
		font-size: 1.05rem;
		line-height: 1.7;
		color: var(--color-text-muted);
		max-width: 520px;
		margin: 0 auto;
	}

	.products-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1.25rem;
	}

	.product-card {
		padding: 2.25rem;
		background: var(--color-bg-card);
		border: 1px solid var(--color-border);
		border-radius: 14px;
		transition: all 0.25s ease;
	}

	.product-card:hover {
		border-color: var(--color-border-hover);
	}

	.product-card.featured {
		grid-row: span 2;
		display: flex;
		flex-direction: column;
		justify-content: center;
		background: linear-gradient(160deg, var(--color-bg-card) 0%, rgba(99, 102, 241, 0.06) 100%);
		border-color: rgba(99, 102, 241, 0.15);
	}

	.product-label {
		font-size: 0.65rem;
		font-weight: 600;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--color-text-dim);
		margin-bottom: 0.75rem;
	}

	.product-card h3 {
		font-size: 1.25rem;
		font-weight: 600;
		margin-bottom: 0.75rem;
	}

	.product-card p {
		font-size: 0.9rem;
		line-height: 1.65;
		color: var(--color-text-muted);
		margin-bottom: 1.5rem;
	}

	.product-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.tag {
		font-size: 0.7rem;
		font-weight: 500;
		padding: 0.3rem 0.75rem;
		background: var(--color-bg-elevated);
		border: 1px solid var(--color-border);
		border-radius: 100px;
		color: var(--color-text-muted);
	}

	@media (max-width: 700px) {
		.products-grid {
			grid-template-columns: 1fr;
		}

		.product-card.featured {
			grid-row: auto;
		}
	}
</style>

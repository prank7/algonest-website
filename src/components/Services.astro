---
const services = [
	{
		icon: "product",
		title: "AI Product Development",
		description: "We build cloud-native SaaS products and mobile apps powered by AI — from MVP to production. Our own products run on the same infrastructure we deploy for clients.",
	},
	{
		icon: "mobile",
		title: "AI-Native iOS Apps",
		description: "Native iOS applications with on-device ML and cloud-synced intelligence. Core ML, server-side LLM inference, and real-time AI features for end users.",
	},
	{
		icon: "automation",
		title: "AI Automation & Agents",
		description: "Production-grade AI agent systems and workflow automation. Cloud-hosted orchestration, GPU-accelerated inference, and scalable data pipelines.",
	},
	{
		icon: "workflow",
		title: "AI Workflow & Data Pipelines",
		description: "Design and deployment of AI-powered data workflows — ETL pipelines, vector search, model serving, and real-time decision systems on cloud infrastructure.",
	},
	{
		icon: "brain",
		title: "AI Strategy & Consulting",
		description: "Help companies integrate AI into their products and operations. From model selection to cloud architecture, we bridge strategy and implementation.",
	},
	{
		icon: "code",
		title: "Cloud-Native Engineering",
		description: "Full-stack engineering for scalable systems. Containerized deployments, serverless APIs, edge computing, CDN delivery, and managed cloud infrastructure.",
	},
];

const icons: Record<string, string> = {
	brain: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a7 7 0 0 1 7 7c0 2.38-1.19 4.47-3 5.74V17a2 2 0 0 1-2 2h-4a2 2 0 0 1-2-2v-2.26C6.19 13.47 5 11.38 5 9a7 7 0 0 1 7-7z"/><path d="M9 22h6"/><path d="M10 22v-2"/><path d="M14 22v-2"/><circle cx="12" cy="9" r="2"/></svg>`,
	mobile: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12" y2="18"/></svg>`,
	automation: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v4"/><path d="M12 18v4"/><path d="M4.93 4.93l2.83 2.83"/><path d="M16.24 16.24l2.83 2.83"/><path d="M2 12h4"/><path d="M18 12h4"/><path d="M4.93 19.07l2.83-2.83"/><path d="M16.24 7.76l2.83-2.83"/><circle cx="12" cy="12" r="4"/></svg>`,
	workflow: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="6" height="6" rx="1"/><rect x="15" y="3" width="6" height="6" rx="1"/><rect x="9" y="15" width="6" height="6" rx="1"/><path d="M6 9v3a1 1 0 0 0 1 1h4"/><path d="M18 9v3a1 1 0 0 1-1 1h-4"/></svg>`,
	code: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/><line x1="14" y1="4" x2="10" y2="20"/></svg>`,
	product: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>`,
};
---

<section id="services" class="services">
	<div class="services-inner">
		<div class="section-header">
			<span class="section-tag">Services</span>
			<h2>What we do</h2>
			<p class="section-sub">
				We build AI-powered products and help companies do the same — from cloud
				infrastructure and ML pipelines to production-ready SaaS and mobile apps.
			</p>
		</div>
		<div class="services-grid">
			{services.map((service) => (
				<div class="service-card">
					<div class="service-icon" set:html={icons[service.icon]} />
					<h3>{service.title}</h3>
					<p>{service.description}</p>
				</div>
			))}
		</div>
	</div>
</section>

<style>
	.services {
		padding: 6rem 2rem;
	}

	.services-inner {
		max-width: var(--max-width);
		margin: 0 auto;
	}

	.section-header {
		text-align: center;
		margin-bottom: 4rem;
	}

	.section-tag {
		display: inline-block;
		font-size: 0.7rem;
		font-weight: 600;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--color-accent-light);
		margin-bottom: 0.75rem;
	}

	.section-header h2 {
		font-size: clamp(1.75rem, 4vw, 2.5rem);
		font-weight: 700;
		letter-spacing: -0.02em;
		margin-bottom: 1rem;
	}

	.section-sub {
		font-size: 1.05rem;
		line-height: 1.7;
		color: var(--color-text-muted);
		max-width: 520px;
		margin: 0 auto;
	}

	.services-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.25rem;
	}

	.service-card {
		padding: 2rem;
		background: var(--color-bg-card);
		border: 1px solid var(--color-border);
		border-radius: 14px;
		transition: all 0.25s ease;
	}

	.service-card:hover {
		border-color: var(--color-border-hover);
		transform: translateY(-2px);
	}

	.service-icon {
		width: 40px;
		height: 40px;
		color: var(--color-accent-light);
		margin-bottom: 1.25rem;
	}

	.service-icon :global(svg) {
		width: 100%;
		height: 100%;
	}

	.service-card h3 {
		font-size: 1.05rem;
		font-weight: 600;
		margin-bottom: 0.625rem;
	}

	.service-card p {
		font-size: 0.875rem;
		line-height: 1.65;
		color: var(--color-text-muted);
	}

	@media (max-width: 900px) {
		.services-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 600px) {
		.services-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
